@code {
    private bool isLoggedIn = false;

    /*
     * the application begins --> NavMenu initializes, this runs every time the app launches
     * async processing due to the eventual use of SecureStorage
     */
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync(); //optional

        //as soon as a component exists, have menu listen for a location change
        navManager.LocationChanged += OnLocationChanged;
        await CheckLoginAsync();

    }
    private async Task CheckLoginAsync()
    {
        //retrieve a possible login token from SecureStorage
        //use the key word name given to the token storage
        var token = await SecureStorage.Default.GetAsync("authToken");

        /*
        * if the token is not found the returned value is null else
            *  the token is returned
            *
            * set a true or false to the isLoggedIn variable
             * we are not concerned with the contents of the token in this example
            * the token only indicates the app has been logged into NOT
             *      that the user is appropriate or valid
            */
        isLoggedIn = !string.IsNullOrEmpty(token);
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await CheckLoginAsync();
        //notify the system that something has changed
        await InvokeAsync(StateHasChanged);

    }

    public void Dispose()
    {
        //dispose of the OnLocationChanged
        navManager.LocationChanged -= OnLocationChanged;
    }

    /*
    * logoff requirements
    * remove the entry from SecureStorage using the key word name
    */
    private async Task Logout()
    {
        SecureStorage.Default.Remove("authToken");
        isLoggedIn = false;
        //force the login page to be displayed (cause by second parameter)
        navManager.NavigateTo("/login", true);
    }
}
